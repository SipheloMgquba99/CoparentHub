# Copy this file to .env and adjust as needed before running `docker compose up --build`.
# All values below have working defaults baked into docker-compose.yml for quick local
# testing — you only need this file if you want to change one of them.

# Postgres password used by both the db container and the api's connection string.
POSTGRES_PASSWORD=Password12345#

# JWT signing secret (must be 32+ bytes) and AES-256-GCM field encryption key (base64, 32 bytes).
# The defaults are the same public dev-only placeholders already in appsettings.Development.json —
# fine for local/testing use, never reuse them anywhere real user data will live.
JWT_SECRET=b2f77657a5967af0e087f2551b489027be85ba313a9e7b9e5265eb4a73c5153adc557cde971802c1b3117bb63d165c544f0d7d853d04707f05fd4a8070ec5004
ENCRYPTION_KEY=uA/jm+UsS5F7TUjucMjcb7KJ/PuawkqdpYFqmFqTD6o=

# Host ports to publish on this machine.
API_PORT=5247
WEB_PORT=8081
SEQ_PORT=5341

# The origin your testers will actually load the frontend from — must match WEB_PORT above,
# or your tunnel's public URL if you're exposing this beyond your own machine.
CORS_ORIGIN=http://localhost:8081

# Baked into the frontend at BUILD time (Vite embeds it into the static JS bundle), so it must be
# the address OTHER machines can reach the API at — not "localhost" if testers aren't on this PC.
# Change this to your LAN IP (e.g. http://192.168.1.50:5247) or your tunnel's backend URL, then
# run `docker compose build web` again for it to take effect.
VITE_API_BASE_URL=http://localhost:5247
