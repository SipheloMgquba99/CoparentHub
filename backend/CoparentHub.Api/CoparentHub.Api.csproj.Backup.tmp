  <ItemGroup>
    <PackageReference Include="MediatR" Version="14.1.0" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.3" />
    <PackageReference Include="Microsoft.OpenApi" Version="1.6.22" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CoparentHub.Application\CoparentHub.Application.csproj" />
    <ProjectReference Include="..\CoparentHub.Domain\CoparentHub.Domain.csproj" />
  </ItemGroup>

</Project>
